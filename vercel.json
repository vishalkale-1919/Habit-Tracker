{
  "version": 2,
  "builds": [
    { 
      "src": "client/package.json", 
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" } 
    },
    { 
      "src": "api/*.js", 
      "use": "@vercel/node" 
    }
  ],
  "routes": [
    { 
      "src": "/api/(.*)", 
      "dest": "/api/$1" 
    },
    { 
      "src": "/assets/(.*)", 
      "dest": "/client/assets/$1" 
    },
    { 
      "src": "/((?!api).*)", 
      "dest": "/client/index.html" 
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}