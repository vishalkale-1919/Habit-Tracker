{
  "version": 2,
  "rewrites": [
    { 
      "source": "/api/(.*)", 
      "destination": "/api/$1" 
    },
    { 
      "source": "/assets/(.*)", 
      "destination": "/client/dist/assets/$1" 
    },
    { 
      "source": "/((?!api).*)", 
      "destination": "/client/dist/index.html" 
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}